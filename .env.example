# Intelligent Knowledge Platform (IKP) Environment Settings

# Core Configuration
# REQUIRED: Google Gemini API Keys for LLM reasoning capabilities.
# You can provide a single key or a comma-separated list of keys for free-tier rotation and failover.
GEMINI_API_KEYS="your-gemini-api-key-here,your-second-key-here"

# Observability Configuration
# Langfuse is used for LLM tracing. The Hobby tier provides 50k traces/month for free.
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_HOST="https://cloud.langfuse.com"

# Path to your OKF Markdown repository
SEEKSTONE_VAULT="./repository"

# Logging configuration
LOG_LEVEL="INFO"
VITE_API_BASE_URL=http://localhost:8000/api
