# Environments and local secrets
.venv/
.env
env/
venv/
ENV/
env.bak/
venv.bak/

# Python bytecode, caches, and build metadata
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / frontend build output
node_modules/
dist/
build/
.npm/
ikp_web/dist/

# IDEs and OS files
.vscode/
.idea/
.DS_Store

# Logs, local runtime state, and local databases
*.log
logs/
*.sqlite3
.chroma/
.*_pid

# Generated knowledge/runtime artifacts
/repository/
history/
work/
tmp/
.temp/
hash.*

# Graphify / Obsidian generated artifacts
**/graphify-out/*
graphify-out/*
!/graphify-out/GRAPH_REPORT.md
!/graphify-out/graph.json
!/graphify-out/manifest.json
.obsidian/
.graphify_obsidian_manifest.json
graph.canvas

# Ignore auto-generated root markdown nodes, but keep project docs tracked.
/*.md
!/README.md
!/CONTEXT.md
!/STATE.md
!/LOG.md
!/SETUP.md
